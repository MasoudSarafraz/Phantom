{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Phantom": {
    "Database": {
      "Provider": "PostgreSQL",
      "ConnectionString": "Host=localhost;Port=5432;Database=myapp;Username=phantom;Password=phantom"
    },
    "Messaging": {
      "Channels": {
        "default": {
          "Type": "InMemory"
        }
      },
      "EventRouting": {
        "MyApp.Domain.Events.ProductCreatedIntegrationEvent, MyApp.Domain": [ "default" ]
      },
      "Retry": {
        "MaxRetries": 3,
        "BaseDelay": "00:00:01"
      },
      "CircuitBreaker": {
        "FailureThreshold": 5,
        "ResetTimeout": "00:00:30"
      }
    },
    "Features": {
      "UseOutbox": true,
      "UseIdempotency": true,
      "UseFluentValidation": true,
      "UseSoftDelete": true,
      "UseAuditable": true,
      "UseCQRS": true
    }
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  }
}
