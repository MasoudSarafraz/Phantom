{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Phantom": {
    "Database": {
      "Provider": "InMemory"
    },
    "Messaging": {
      "Channels": {
        "default": { "Type": "InMemory" }
      }
    },
    "Features": {
      "UseOutbox": false,
      "UseIdempotency": false
    }
  }
}
